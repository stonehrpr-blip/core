# Supabase (public — safe to expose in client)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Analytics
EXPO_PUBLIC_POSTHOG_KEY=phc_YOUR_KEY
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Errors
EXPO_PUBLIC_SENTRY_DSN=https://YOUR@sentry.io/PROJECT

# RevenueCat (public SDK keys — safe to expose)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_YOUR_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_YOUR_KEY

# Server-only secrets go in supabase/functions env, never here:
#   ANTHROPIC_API_KEY
#   OPENAI_API_KEY
#   REVENUECAT_WEBHOOK_SECRET
