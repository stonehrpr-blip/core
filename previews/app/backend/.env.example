# ─── Database ─────────────────────────────────────────────────────────────
# Production (Neon free tier or Supabase free)
DATABASE_URL="postgresql://USER:PASS@HOST/core?sslmode=require"

# ─── Auth + Security ──────────────────────────────────────────────────────
# 32-byte hex secret for JWT signing (run: openssl rand -hex 32)
JWT_SECRET="REPLACE_WITH_64_HEX_CHARS"
# 32-byte AES-256-GCM key for encrypting sensitive fields at rest
ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHARS"
# Salt rounds for bcrypt password hashing (10-12 production)
BCRYPT_ROUNDS=12
# Session lifetime
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="30d"

# ─── Stripe (web checkout + portal) ───────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MONTHLY="price_..."   # $7.99/mo · created in Stripe Dashboard
STRIPE_PRICE_YEARLY="price_..."    # $59.00/yr (~38% off vs $96/yr if billed monthly)

# ─── Apple StoreKit V2 ────────────────────────────────────────────────────
APPLE_BUNDLE_ID="com.harperlinks.core"
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
# Path to the .p8 issuer key (mount as a secret)
APPLE_PRIVATE_KEY_PATH="/secrets/AuthKey_XXXXXXXX.p8"
# "Production" for live, "Sandbox" for testing
APPLE_ENV="Sandbox"
# App Store Connect issuer ID (for App Store Server API calls)
APPLE_ISSUER_ID=""

# ─── Push notifications ───────────────────────────────────────────────────
# Apple APNs (uses the same .p8 key as StoreKit)
APNS_TOPIC="com.harperlinks.core"
APNS_KEY_ID=""
APNS_TEAM_ID=""
# Optional override of the host (defaults to production in NODE_ENV=production)
APNS_HOST=""
# Firebase Cloud Messaging (Android + web push)
FCM_SERVICE_ACCOUNT_JSON_PATH="/secrets/fcm-service-account.json"
# VAPID keys for web push standalone — generate via `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:no-reply@harperlinks.com"
# PagerDuty Events API v2 routing key (Service → Integrations → Events API v2)
PAGERDUTY_ROUTING_KEY=""

# ─── Rate limiting ────────────────────────────────────────────────────────
# Upstash Redis for distributed rate limits (optional — falls back to DB)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Misc ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
# Owner email (only this user can hit /api/admin/*)
OWNER_EMAIL="stonehrprzilo@gmail.com"
# bcrypt-hashed owner PIN (used for admin.html auth)
OWNER_PIN_HASH=""
# ─── AI Coach (Phase 8) ───────────────────────────────────────────────────
# Provider: "openai" (default) or "anthropic"
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Optional Sentry DSN for crash reporting
SENTRY_DSN=""
# Resend (email transport)
RESEND_API_KEY=""
RESEND_FROM="CORE <no-reply@harperlinks.com>"
# Cron failure alerting (Slack incoming webhook — Owner gets email fallback if unset)
SLACK_WEBHOOK_URL=""
# One-time owner-setup bootstrap token. Set, use once, then set OWNER_SETUP_LOCKED=1.
SETUP_BOOTSTRAP_TOKEN=""
OWNER_SETUP_LOCKED=""
# Optional IP allowlist for /api/setup/owner — comma-separated IPs
SETUP_ALLOWED_IPS=""
# Vercel Cron bearer secret
CRON_SECRET=""
# Apple: dir containing Apple's root CA certs (.cer/.pem files)
APPLE_ROOT_CERTS_DIR="/secrets/apple-certs"
# Apple App ID (numeric, from App Store Connect)
APPLE_APP_APPLE_ID=""
# Allow family-shared subscriptions to grant Pro (default: blocked)
APPLE_ALLOW_FAMILY_SHARING=""
# Public app origin for CORS + CSRF
NEXT_PUBLIC_APP_ORIGIN="https://core.harperlinks.com"
