// Prisma schema for CORE — production-grade.
// Stack: PostgreSQL (Neon / Supabase / Railway / RDS).
// Run: `pnpm prisma generate && pnpm prisma db push`
//
// Enums explicit. Indexes on every hot lookup path. Cascading deletes only
// where it's safe (a User's own data; never cross-user content).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum Tier {
  FREE
  PRO
}

enum SubscriptionStatus {
  TRIALING       // 7-day free trial active
  ACTIVE         // paying subscriber
  GRACE_PERIOD   // billing failed, Apple/Stripe is retrying
  PAST_DUE       // multiple failures, still recoverable
  CANCELLED      // user cancelled, will expire at period end
  EXPIRED        // ended, downgraded to free
  REFUNDED       // Apple/Stripe refunded — premium revoked immediately
}

enum BillingProvider {
  APPLE          // StoreKit V2 — iOS App Store
  STRIPE         // Stripe — web/PWA
  NONE           // free tier, no billing record
}

enum DeviceKind {
  IOS
  ANDROID
  WEB
}

enum NotificationKind {
  STREAK_REMINDER
  TRIAL_EXPIRING
  BILLING_FAILED
  COACH_NUDGE
  ACHIEVEMENT_UNLOCKED
  FRIEND_SLIPPED
  COIN_RECEIVED
  GENERIC
}

enum ReportReason {
  SPAM
  HARASSMENT
  SELF_HARM
  HATE_SPEECH
  MISINFO
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED_KEPT
  REVIEWED_REMOVED
  ESCALATED
}

enum AdminAction {
  LOGIN
  USER_VIEW
  USER_BAN
  USER_UNBAN
  REFUND_ISSUED
  POST_REMOVED
  PIN_CHANGED
  DATA_EXPORT
}

enum FeedSection {
  FITNESS
  MIND
  WALLET
  BODY
  STREAKS
}

// ─── Core user ────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  handle      String   @unique
  displayName String
  avatarKey   String   @default("core")
  bio         String?
  isPrivate   Boolean  @default(false)
  isBanned    Boolean  @default(false)
  bannedAt    DateTime?
  bannedReason String?

  // Auth
  passwordHash    String?  // bcrypt; null when using OAuth/Apple/Google only
  emailVerified   Boolean  @default(false)
  emailVerifiedAt DateTime?

  // Subscription state (mirrored from active Subscription record for fast reads)
  tier                Tier               @default(FREE)
  subscriptionStatus  SubscriptionStatus @default(EXPIRED)
  trialEndsAt         DateTime?
  // Compliance — anti-fraud signals
  signupIp            String?
  signupCountry       String?            // ISO-3166-1 alpha-2
  riskScore           Float              @default(0)   // 0-1; updated nightly
  refundCount         Int                @default(0)

  // State (matches localStorage shape from coreState)
  xp                  Int      @default(0)
  coins               Int      @default(100)
  level               Int      @default(1)
  stats               Json     @default("{\"brain\":0,\"lungs\":0,\"wallet\":0,\"willpower\":0,\"body\":0}")
  iconsOwned          String[] @default(["core"])
  statWizardsDone     Json     @default("{}")
  doubleXpUntil       DateTime?

  // Push
  pushTokenIos        String?
  pushTokenAndroid    String?
  pushTokenWeb        String?
  pushOptedIn         Boolean  @default(false)
  timezone            String?  // IANA, e.g. "Australia/Perth"

  // Referral
  referralCode        String?  @unique
  referredByUserId    String?
  referredBy          User?    @relation("ReferredBy", fields: [referredByUserId], references: [id])
  referrals           User[]   @relation("ReferredBy")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  subscriptions        Subscription[]
  transactions         Transaction[]
  trialState           TrialState?
  notifications        Notification[]
  achievements         AchievementUnlock[]
  streak               Streak?
  habits               Habit[]
  posts                Post[]
  comments             Comment[]
  likes                Like[]
  follows              Follow[]            @relation("follower")
  followers            Follow[]            @relation("following")
  sentTransfers        CoinTransfer[]      @relation("from")
  receivedTransfers    CoinTransfer[]      @relation("to")
  reportsMade          Report[]            @relation("reporter")
  reportsAbout         Report[]            @relation("subject")
  refunds              Refund[]
  deviceSessions       DeviceSession[]
  adminLogs            AdminLog[]          @relation("actor")
  adminActionsOn       AdminLog[]          @relation("target")
  auditLogs            AuditLog[]
  insightDismissals    InsightDismissal[]
  slipLogs             SlipLog[]
  coinLedger           CoinLedger[]

  @@index([email])
  @@index([handle])
  @@index([tier, subscriptionStatus])
  @@index([createdAt])
  @@index([referredByUserId])
}

// ─── Subscription state machine ──────────────────────────────────────────

model Subscription {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider     BillingProvider
  status       SubscriptionStatus

  // Provider-specific identifiers
  appleOriginalTxId    String?  // StoreKit V2 originalTransactionId — Apple's stable subscription ID
  appleLatestTxId      String?  // most recent transactionId
  appleProductId       String?  // e.g. "core_pro_monthly"
  appleEnvironment     String?  // "Production" | "Sandbox"

  stripeCustomerId       String?
  stripeSubscriptionId   String? @unique
  stripePriceId          String?

  // Cycle dates
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  cancelledAt          DateTime?
  expiredAt            DateTime?

  // Billing retry / grace
  gracePeriodEnd       DateTime?
  failedPaymentCount   Int      @default(0)
  lastFailedAt         DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
  @@index([provider, status])
  @@index([appleOriginalTxId])
  @@index([stripeSubscriptionId])
  @@index([currentPeriodEnd])
}

model TrialState {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt         DateTime @default(now())
  endsAt            DateTime
  applePayConnected Boolean  @default(false)
  applePayConnectedAt DateTime?
  converted         Boolean  @default(false)
  convertedAt       DateTime?
  cancelledDuringTrial Boolean @default(false)

  @@index([endsAt, converted])
}

// ─── Money — transactions, refunds, transfers ─────────────────────────────

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?
  provider       BillingProvider

  amountCents    Int       // gross amount in cents (USD)
  feeCents       Int       // Apple/Stripe cut
  netCents       Int       // amount you actually receive
  currency       String    @default("USD")

  // Identifiers from providers
  appleTransactionId   String?  @unique
  stripeChargeId       String?  @unique
  stripeInvoiceId      String?  @unique

  description    String?
  occurredAt     DateTime  @default(now())
  refundedAt     DateTime?

  @@index([userId, occurredAt])
  @@index([provider, occurredAt])
  @@index([occurredAt])
}

model Refund {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String
  amountCents   Int
  reason        String?
  provider      BillingProvider
  // Apple's CONSUMPTION_REQUEST notification routes here for our reply
  appleConsumptionStatus String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

model CoinTransfer {
  id        String   @id @default(cuid())
  fromId    String
  from      User     @relation("from", fields: [fromId], references: [id])
  toId      String
  to        User     @relation("to",   fields: [toId],   references: [id])
  amount    Int
  reason    String   // 'transfer' | 'gift_flame' | ...
  note      String?
  createdAt DateTime @default(now())

  @@index([fromId, createdAt])
  @@index([toId, createdAt])
}

model CoinLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int       // + earn, - spend
  reason    String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([reason, createdAt])
}

// ─── User-generated content + social ──────────────────────────────────────

model Habit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitKey    String   // 'vape' | 'porn' | 'doomscroll' | 'spend' | ...
  displayName String
  startedAt   DateTime @default(now())
  archivedAt  DateTime?

  @@unique([userId, habitKey])
  @@index([userId])
}

model SlipLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit     String
  magnitude Int      @default(1)
  ts        DateTime @default(now())

  @@index([userId, ts])
  @@index([habit, ts])
}

model Streak {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  days            Int      @default(0)
  startedAt       DateTime?
  lastCleanAt     DateTime?
  lostAt          DateTime?
  previousDays    Int      @default(0)
  freezesAvailable Int     @default(1)
  freezesResetAt   DateTime?
  restoresUsedFree Int     @default(0)

  @@index([days])
}

model Post {
  id        String      @id @default(cuid())
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  section   FeedSection
  text      String      @db.VarChar(320)
  scoreSnap Json        // { label, n, unit } frozen at post time
  removedAt DateTime?
  removedReason String?
  createdAt DateTime    @default(now())

  likes     Like[]
  comments  Comment[]
  reports   Report[]

  @@index([section, createdAt])
  @@index([authorId, createdAt])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  text      String   @db.VarChar(500)
  removedAt DateTime?
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([authorId])
}

model Like {
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@index([postId])
}

model Follow {
  followerId  String
  follower    User     @relation("follower",  fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followingId, createdAt])
}

// ─── Moderation ────────────────────────────────────────────────────────────

model Report {
  id          String        @id @default(cuid())
  reporterId  String
  reporter    User          @relation("reporter", fields: [reporterId], references: [id])
  subjectId   String        // user being reported
  subject     User          @relation("subject",  fields: [subjectId], references: [id])
  postId      String?
  post        Post?         @relation(fields: [postId], references: [id])
  reason      ReportReason
  detail      String?
  status      ReportStatus  @default(PENDING)
  reviewedAt  DateTime?
  reviewerId  String?
  createdAt   DateTime      @default(now())

  @@index([status, createdAt])
  @@index([subjectId])
}

// ─── Achievements + stats ────────────────────────────────────────────────

model AchievementUnlock {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleId     String   // 'streak_7' | 'first_post' | ...
  unlockedAt DateTime @default(now())

  @@unique([userId, ruleId])
  @@index([ruleId, unlockedAt])
}

model UserStatsSnapshot {
  // Daily aggregate per user — for charts + retention analysis
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  brain     Int
  lungs     Int
  wallet    Int
  willpower Int
  body      Int
  lifeScore Int
  xp        Int
  coins     Int
  streak    Int

  @@unique([userId, date])
  @@index([date])
}

model InsightDismissal {
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  insightId   String
  dismissedAt DateTime @default(now())

  @@id([userId, insightId])
}

// ─── Push + Notifications ─────────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       NotificationKind
  title      String
  body       String
  meta       Json?
  scheduledFor DateTime?
  sentAt     DateTime?
  deliveredAt DateTime?
  openedAt   DateTime?
  failed     Boolean          @default(false)
  failedReason String?
  createdAt  DateTime         @default(now())

  @@index([userId, sentAt])
  @@index([scheduledFor])
  @@index([kind, sentAt])
}

// ─── Security ──────────────────────────────────────────────────────────────

model DeviceSession {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Hashed refresh token (sha256); raw token only ever exists in the cookie
  refreshTokenHash String  @unique
  deviceKind    DeviceKind
  // Browser fingerprint for the device tying
  fingerprint   String
  userAgent     String?
  ip            String?
  country       String?
  // Session lifecycle
  createdAt     DateTime   @default(now())
  lastUsedAt    DateTime   @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?

  @@index([userId, expiresAt])
  @@index([refreshTokenHash])
  @@index([fingerprint])
}

model FailedLogin {
  // Brute-force tracking
  id        String   @id @default(cuid())
  // Either email or IP — we track both
  identifier String
  ip        String?
  ts        DateTime @default(now())
  reason    String?

  @@index([identifier, ts])
  @@index([ip, ts])
}

model AccountLockout {
  // Account-level lockout after N failed logins. Auto-expires.
  identifier String   @id           // email (lowercased)
  lockedAt   DateTime @default(now())
  unlocksAt  DateTime
  reason     String

  @@index([unlocksAt])
}

model EmailOtp {
  // 6-digit one-time code with TTL, used for: email verification, password reset, 2FA login,
  // owner-dashboard secondary auth.
  id         String   @id @default(cuid())
  userId     String?
  email      String
  purpose    OtpPurpose
  codeHash   String                // bcrypt-hashed; we never store plaintext
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int      @default(0)  // increments on each verify miss
  ip         String?
  createdAt  DateTime @default(now())

  @@index([email, purpose, expiresAt])
  @@index([userId, purpose])
}

enum OtpPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
  TWO_FA_LOGIN
  OWNER_DASHBOARD
}

model TwoFactorEnrollment {
  // Per-user 2FA preference. We only support email OTP for now (Phase 4),
  // TOTP via authenticator app lands in a later phase if needed.
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  method    TwoFactorMethod
  enabledAt DateTime @default(now())
  // Backup codes (hashed). One-time use.
  backupCodeHashes String[] @default([])

  @@index([method])
}

enum TwoFactorMethod {
  EMAIL_OTP
}

model OwnerSecret {
  // Server-side owner PIN — bcrypt hash. Replaces localStorage.coreOwnerPin from admin.html.
  // One row. Identified by email; only the user matching env.OWNER_EMAIL can hit admin routes.
  email    String   @id
  pinHash  String
  // Last rotation time for compliance.
  rotatedAt DateTime @default(now())
  // Optional second factor — if set, owner must provide both PIN + 2FA on every session
  requireOtp Boolean @default(true)
}

model OwnerSession {
  // Short-lived owner-dashboard session, separate from regular user sessions.
  // Owner-PIN-verified-once-then-trusted-for-N-minutes pattern.
  id           String   @id @default(cuid())
  userId       String
  refreshHash  String   @unique
  fingerprint  String
  ip           String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  @@index([userId, expiresAt])
}

// ─── AI Coach ──────────────────────────────────────────────────────────────

model CoachConversation {
  // One row per active conversation. Reset (idle > 4h) closes the active one
  // and opens a new one on next message. Old conversations stay for analytics.
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Tone the user has configured (gentle/balanced/direct/drill)
  tone         String   @default("balanced")
  // Sliding context summary — kept short so we don't blow the token budget
  summary      String?
  startedAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  closedAt     DateTime?
  messageCount Int      @default(0)

  messages     CoachMessage[]

  @@index([userId, lastActiveAt])
  @@index([closedAt])
}

model CoachMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           CoachRole
  content        String                       @db.Text
  // Tokens consumed by this message (cost tracking)
  promptTokens     Int?
  completionTokens Int?
  // Which model answered (for A/B + cost analysis)
  model            String?
  // Was this a recommendation push (sent unprompted) or a chat reply?
  unprompted       Boolean @default(false)
  ts             DateTime @default(now())

  @@index([conversationId, ts])
}

enum CoachRole {
  USER
  ASSISTANT
  SYSTEM
}

model RecommendationCache {
  // The recommendation engine writes 1-3 nudges per user per day. The Coach
  // surfaces them on first message of a new session and the dashboard fetches
  // them as insight cards.
  id        String   @id @default(cuid())
  userId    String   @unique
  generated DateTime @default(now())
  nudges    Json     // Array<{ id, title, body, action, urgency }>

  @@index([generated])
}

model ReminderTemplate {
  // Predefined notification campaigns (Coach can schedule these for the user).
  id           String           @id @default(cuid())
  key          String           @unique           // 'morning_checkin' | 'bedtime' | …
  title        String
  body         String
  kind         NotificationKind
  // When (offset from "9am user local"), or cron-style "DAILY 21:00" — interpreted by scheduler
  whenSpec     String
  enabled      Boolean          @default(true)
  createdAt    DateTime         @default(now())
}

model SuspiciousLogin {
  // Anomaly log: signins from new countries / new fingerprints / impossible-travel
  id          String   @id @default(cuid())
  userId      String
  reason      String   // 'new_country' | 'new_device' | 'impossible_travel' | 'too_many_devices'
  fromIp      String?
  fromCountry String?
  fingerprint String?
  detail      Json?
  resolvedAt  DateTime?  // null = pending review by user
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model AdminLog {
  // Audit trail for owner / admin actions in admin.html
  id        String      @id @default(cuid())
  actorId   String
  actor     User        @relation("actor",  fields: [actorId],  references: [id])
  targetId  String?
  target    User?       @relation("target", fields: [targetId], references: [id])
  action    AdminAction
  meta      Json?
  ip        String?
  ts        DateTime    @default(now())

  @@index([actorId, ts])
  @@index([action, ts])
}

model AuditLog {
  // Catch-all log for sensitive user-side actions (sign-in, password reset, data export)
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  event     String
  meta      Json?
  ip        String?
  ts        DateTime @default(now())

  @@index([userId, ts])
  @@index([event, ts])
}

model RateLimitBucket {
  // Persistent rate-limit counters for endpoints that can't be in-memory only
  key       String   @id          // "coin_send:userId:abc" or "login:ip:1.2.3.4"
  count     Int      @default(0)
  windowEnd DateTime

  @@index([windowEnd])
}

// ─── Webhook idempotency ────────────────────────────────────────────────────
//
// Apple App Store Server Notifications + Stripe both retry on network failure
// and may deliver the same event twice. Without atomic dedupe we double-bill,
// double-grant, double-refund. This table is the canonical "have we seen
// this delivery before?" record. The unique constraint makes the
// check-then-insert race impossible — concurrent handlers either succeed
// (first one wins) or get a P2002 (every other one bails).

model ProcessedWebhook {
  id         String   @id @default(cuid())
  provider   String   // "apple_storekit" | "stripe"
  externalId String   // Apple notificationUUID / Stripe event.id
  kind       String?  // event type (informational)
  createdAt  DateTime @default(now())

  @@unique([provider, externalId])
  @@index([createdAt])
}

// ─── Analytics ─────────────────────────────────────────────────────────────

model AnalyticsEvent {
  // Raw event ingestion table. Daily roll-ups go into AnalyticsDaily.
  id        String   @id @default(cuid())
  userId    String?  // nullable for pre-auth events
  sessionId String?
  event     String   // "post_created" | "stat_quiz_completed" | ...
  meta      Json?
  ip        String?
  ua        String?
  country   String?
  ts        DateTime @default(now())

  @@index([event, ts])
  @@index([userId, ts])
  @@index([ts])
}

model AnalyticsDaily {
  // One row per (event, date) — fast aggregates for the admin dashboard
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  event     String
  count     Int
  uniqueUsers Int

  @@unique([date, event])
  @@index([date])
}

model RevenueDaily {
  // One row per date — admin dashboard's MRR / churn / cohort engine sources from here
  date              DateTime @id @db.Date
  // Channel splits (cents)
  appleGrossCents   Int      @default(0)
  appleFeeCents     Int      @default(0)
  appleNetCents     Int      @default(0)
  stripeGrossCents  Int      @default(0)
  stripeFeeCents    Int      @default(0)
  stripeNetCents    Int      @default(0)
  refundCents       Int      @default(0)
  // Subscriber counts at end of day
  paidActive        Int      @default(0)
  trialing          Int      @default(0)
  expired           Int      @default(0)
  freeUsers         Int      @default(0)
  newSignups        Int      @default(0)
  newPaidConverts   Int      @default(0)
  cancellations     Int      @default(0)

  @@index([date])
}

model RetentionCohort {
  // Cohort retention table — built by daily job
  cohortDate    DateTime @db.Date
  dayOffset     Int      // 1, 7, 30, 90
  retained      Int
  cohortSize    Int

  @@id([cohortDate, dayOffset])
}
